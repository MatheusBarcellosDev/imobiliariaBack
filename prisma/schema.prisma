// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(uuid())
  name      String
  email     String   @unique
  password  String
  role      Role     @default(AGENT)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  leads     Lead[]
}

enum Role {
  ADMIN
  AGENT
}

model Property {
  id          String   @id @default(uuid())
  title       String
  description String
  price       Float
  area        Float
  bedrooms    Int
  bathrooms   Int
  garages     Int
  type        String   // e.g "Apartamento", "Casa"
  status      String   // e.g "Venda", "Aluguel"
  images      String[] // Array de URLs
  featured    Boolean  @default(false)

  // -- Campos Avançados para Listagem "Muito Completa" --
  amenities   String[] // ex: ["Piscina", "Academia", "Varanda Gourmet"]
  documents   String[] // ex: Array de URLs para PDFs como Matricula, Planta, Laudos
  iptu        Float?
  condoFee    Float?
  yearBuilt   Int?
  floorPlan   String?  // URL para a imagem da planta baixa
  
  // Informações Básicas Adicionais
  referenceCode    String?
  shortDescription String?
  condition        String? // Ex: Usado, Novo, Em construção, Na planta

  // Preços e Valores Financeiros Adicionais
  rentPrice        Float?
  maintenanceFee   Float?
  priceNegotiable  Boolean @default(false)
  acceptsFinancing Boolean @default(false)
  acceptsExchange  Boolean @default(false)

  // Localização Completa Adicional (Lat/Lng e Address já existem)
  country          String  @default("Brasil")
  state            String?
  city             String?
  street           String?
  number           String?
  complement       String?
  zipCode          String?

  // Cômodos e Estrutura Adicionais (bedrooms, bathrooms, garages, area já existem)
  suites           Int     @default(0)
  usefulArea       Float?
  privateArea      Float?
  landArea         Float?
  floors           Int?    // Andar do apto
  buildingFloors   Int?    // Andares do Edifício
  aptsPerFloor     Int?

  // Detalhes Técnicos
  sunOrientation   String?
  sunExposure      String?
  viewType         String?
  windowType       String?
  floorType        String?

  // Informações do Condomínio
  condoName        String?
  condoAdmin       String?
  condoBuilder     String?
  constructionProfile String? // Ex: Alto Padrão, MCMV
  totalUnits       Int?
  totalElevators   Int?
  condoAmenities   String[] // Infraestrutura e Lazer do condomínio

  // Informações Comerciais e Permuta
  zoning           String?
  commission       Float?
  debtBalance      Float?
  remainingInstallments Int?
  exchangeOptions  String[] // Ex: ["Veículo", "Imóvel", "Dação"]

  // SEO
  seoTitle         String?
  seoDescription   String?
  seoKeywords      String?

  // Status e Gestão Interna (featured já existe)
  published        Boolean @default(true)
  superFeatured    Boolean @default(false)
  newRelease       Boolean @default(false)
  hasBoard         Boolean @default(false) // Placa no local
  exclusive        Boolean @default(false)
  
  keyLocation        String?
  keyManager         String? // Ex: Zeladoria / Portaria
  managerName        String?
  managerPhone       String?
  internalNotes      String?
  visitInstructions  String?

  neighborhoodId String?
  neighborhood   Neighborhood? @relation(fields: [neighborhoodId], references: [id])
  
  address     String?
  lat         Float?
  lng         Float?

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Neighborhood {
  id          String     @id @default(uuid())
  name        String
  description String?
  image       String?
  properties  Property[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

model Lead {
  id          String     @id @default(uuid())
  name        String
  email       String
  phone       String?
  source      String     @default("CHATBOT") // Ex: CHATBOT, SITE
  status      LeadStatus @default(NOVO)
  message     String?    // Mensagem inicial
  
  agentId     String?
  agent       User?      @relation(fields: [agentId], references: [id])

  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
}

enum LeadStatus {
  NOVO
  CONTATO_INICIAL
  VISITA_AGENDADA
  PROPOSTA
  FECHADO
  PERDIDO
}
